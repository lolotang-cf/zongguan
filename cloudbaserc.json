{
  "envId": "lolotang-d4g5f9sq0fbe9c235",
  "version": "2.0",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "framework": {
    "name": "zongguan-platform",
    "plugins": {
      "node-api": {
        "use": "@cloudbase/framework-plugin-cloudrun",
        "inputs": {
          "name": "zongguan-platform",
          "path": "/",
          "containerPort": 80,
          "cpu": 0.5,
          "mem": 1,
          "minNum": 0,
          "maxNum": 5,
          "dockerfile": "Dockerfile",
          "buildDir": "",
          "envVariables": {
            "NODE_ENV": "production",
            "PORT": "80"
          }
        }
      }
    },
    "buildCommand": "",
    "installCommand": ""
  },
  "cloudrun": {
    "name": "zongguan-platform"
  },
  "functionRoot": "./functions",
  "functions": [
    {
      "name": "zongguan-api",
      "timeout": 30,
      "runtime": "Nodejs18.15",
      "handler": "index.main",
      "envVariables": {
        "DEPLOY_MODE": "event",
        "NODE_ENV": "production"
      }
    }
  ]
}
